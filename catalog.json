{
  "exporters": [
    {
      "name": "alertmanager",
      "description": "Handle alerts and notifications for the Prometheus ecosystem",
      "version": "0.30.0",
      "upstream": {
        "type": "github",
        "repo": "prometheus/alertmanager",
        "strategy": "latest_release"
      },
      "build": {
        "method": "binary_repack",
        "binary_name": "alertmanager",
        "extra_binaries": [
          "amtool"
        ]
      },
      "artifacts": {
        "rpm": {
          "enabled": true,
          "targets": [
            "el8",
            "el9",
            "el10"
          ],
          "summary": "Prometheus Alertmanager",
          "service_file": true,
          "system_user": "alertmanager",
          "extra_files": [
            {
              "source": "assets/alertmanager.yml",
              "dest": "/etc/alertmanager/alertmanager.yml",
              "config": true
            }
          ],
          "directories": [
            {
              "path": "/etc/alertmanager",
              "mode": "0755",
              "owner": "root",
              "group": "root"
            },
            {
              "path": "/var/lib/alertmanager",
              "mode": "0755",
              "owner": "alertmanager",
              "group": "alertmanager"
            }
          ]
        },
        "docker": {
          "enabled": true,
          "entrypoint": [
            "/usr/bin/alertmanager"
          ],
          "cmd": [
            "--config.file=/etc/alertmanager/alertmanager.yml"
          ],
          "validation": {
            "port": 9093
          }
        }
      },
      "availability": {
        "el8": {
          "x86_64": {
            "status": "success",
            "path": "el8/x86_64/alertmanager-0.30.0-1.el8.x86_64.rpm"
          },
          "aarch64": {
            "status": "success",
            "path": "el8/aarch64/alertmanager-0.30.0-1.el8.aarch64.rpm"
          }
        },
        "el9": {
          "x86_64": {
            "status": "success",
            "path": "el9/x86_64/alertmanager-v0.30.0-1.el9.x86_64.rpm"
          },
          "aarch64": {
            "status": "success",
            "path": "el9/aarch64/alertmanager-0.30.0-1.el9.aarch64.rpm"
          }
        },
        "el10": {
          "x86_64": {
            "status": "success",
            "path": "el10/x86_64/alertmanager-0.30.0-1.el10.x86_64.rpm"
          },
          "aarch64": {
            "status": "success",
